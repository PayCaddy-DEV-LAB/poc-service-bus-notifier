{
  "UserConfig": {
    "Namespaces": [
      {
        "Name": "sbemulatorns",
        "Queues": [],
        "Topics": [
          {
            "Name": "webhook-events",
            "Properties": {
              "DefaultMessageTimeToLive": "PT1H",
              "DuplicateDetectionHistoryTimeWindow": "PT1M",
              "RequiresDuplicateDetection": false,
              "EnablePartitioning": false,
              "MaxSizeInMegabytes": 1024,
              "MaxMessageSizeInKilobytes": 1024
            },
            "Subscriptions": [
              {
                "Name": "client-acme",
                "Properties": {
                  "MaxDeliveryCount": 3,
                  "LockDuration": "PT30S",
                  "DefaultMessageTimeToLive": "PT1H",
                  "DeadLetteringOnMessageExpiration": false,
                  "EnableDeadLetteringOnFilterEvaluationExceptions": true
                },
                "Rules": [
                  {
                    "Name": "clientIdFilter",
                    "Properties": {
                      "FilterType": "Sql",
                      "SqlFilter": {
                        "SqlExpression": "clientId = 'acme'"
                      }
                    }
                  }
                ]
              },
              {
                "Name": "client-firstbank",
                "Properties": {
                  "MaxDeliveryCount": 3,
                  "LockDuration": "PT30S",
                  "DefaultMessageTimeToLive": "PT1H",
                  "DeadLetteringOnMessageExpiration": false,
                  "EnableDeadLetteringOnFilterEvaluationExceptions": true
                },
                "Rules": [
                  {
                    "Name": "clientIdFilter",
                    "Properties": {
                      "FilterType": "Sql",
                      "SqlFilter": {
                        "SqlExpression": "clientId = 'firstbank'"
                      }
                    }
                  }
                ]
              },
              {
                "Name": "client-a41315dd-fdee-4ff3-a0c9-01905aa9dc2c",
                "Properties": {
                  "MaxDeliveryCount": 3,
                  "LockDuration": "PT30S",
                  "DefaultMessageTimeToLive": "PT1H",
                  "DeadLetteringOnMessageExpiration": false,
                  "EnableDeadLetteringOnFilterEvaluationExceptions": true
                },
                "Rules": [
                  {
                    "Name": "clientIdFilter",
                    "Properties": {
                      "FilterType": "Sql",
                      "SqlFilter": {
                        "SqlExpression": "clientId = 'a41315dd-fdee-4ff3-a0c9-01905aa9dc2c'"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
    "Logging": {
      "Type": "File"
    }
  }
}
